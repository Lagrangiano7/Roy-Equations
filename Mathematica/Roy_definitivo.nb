Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Definimos", " ", "el", " ", "rango", " ", "de", " ", "s", " ", "y", " ", 
    "la", " ", "cantidad", " ", "de", " ", "puntos"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"smin", "=", 
     RowBox[{"sth", "+", "0.001"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"tu", " ", "l\[IAcute]mite", " ", "inferior"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"smax", "=", "1.2"}], ";"}], "           ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"l\[IAcute]mite", " ", "superior"}], ",", 
     RowBox[{"ajusta", " ", "si", " ", "quieres"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"npoints", "=", "50"}], ";"}], "         ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"n\[UAcute]mero", " ", "de", " ", "puntos"}], ",", 
     RowBox[{
     "puedes", " ", "aumentar", " ", "para", " ", "mayor", " ", 
      "precisi\[OAcute]n"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generamos", " ", "la", " ", "tabla", " ", "de", " ", "valores"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"s", ",", 
         RowBox[{"contrib00", "[", "s", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s", ",", "smin", ",", "smax", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"smax", "-", "smin"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"npoints", "-", "1"}], ")"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Exportamos", " ", "a", " ", "un", " ", "archivo", " ", "CSV"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<contrib00_highenergy.csv\>\"", ",", "data"}], 
    "]"}]}]}]], "Input",
