 RowBox[{
  RowBox[{
   RowBox[{"contrib04", "[", 
    RowBox[{"s_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"64", " ", "Pi"}], ")"}]}], ")"}], " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{"4", ",", " ", "x"}], "]"}], "*", 
       RowBox[{"integralSPrime0", "[", 
        RowBox[{"s", ",", 
         RowBox[{"tt", "[", 
          RowBox[{"s", ",", "x"}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "15"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}], ";"}]], "Input",
