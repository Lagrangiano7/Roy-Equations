7e6ab1ea5f20"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"integralSPrime0", "[", 
    RowBox[{
     RowBox[{"s_", "?", "NumericQ"}], ",", 
     RowBox[{"t_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"integrandI0", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"sp", ",", "s2", ",", " ", "Infinity"}], "}"}], ",", 
     RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
     RowBox[{"MaxRecursion", "->", "20"}], ",", 
     RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983171270680294*^9, 3.9831712937412186`*^9}, {
  3.9831713368232*^9, 3.9831713406265545`*^9}, {3.9831716929938583`*^9, 
  3.9831717043990192`*^9}, {3.983171815173975*^9, 3.983171818312828*^9}, {
