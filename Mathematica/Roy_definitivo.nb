Cell["\<\
        -(1/(Pi*(s - sp))) + (643*s**4)/(512.*Pi*sp*(sp - sth)**4) - \
(3*s**3*(24624*sp + 659*sth))/(512.*Pi*sp*(sp - sth)**4) - 
     -  (s**2*(1535072*sp**2 - 75728*sp*sth - 1353*sth**2))/(512.*Pi*sp*(sp - \
sth)**4) - 
     -  (s*(7575712*sp**3 - 43808*sp**2*sth + 24192*sp*sth**2 - \
493*sth**3))/(512.*Pi*sp*(sp - sth)**4) - 
     -  (25*(17472*sp**4 + 32538*sp**3*sth + 10623*sp**2*sth**2 + \
490*sp*sth**3 + 8*sth**4))/(16.*Pi*(s - sth)*(sp - sth)**4) - 
     -  (468066*sp**4 + 209911*sp**3*sth + 13146*sp**2*sth**2 - 64*sp*sth**3 \
+ 16*sth**4)/(16.*Pi*sp*(sp - sth)**4) - 
     -  (5*(4882*sp**5 + 16482*sp**4*sth + 10857*sp**3*sth**2 + \
1152*sp**2*sth**3 + 52*sp*sth**4))/(2.*Pi*(s - sth)**2*(sp - sth)**4) - 
     -  (105*(46*sp**6 + 266*sp**5*sth + 351*sp**4*sth**2 + 66*sp**3*sth**3 + \
6*sp**2*sth**4))/(2.*Pi*(s - sth)**3*(sp - sth)**4) - 
     -  (210*(sp**7 + 6*sp**6*sth + 21*sp**5*sth**2 + 6*sp**4*sth**3 + \
sp**3*sth**4))/(Pi*(s - sth)**4*(sp - sth)**4) + 
     -  (3*(-70*sp**4 - 90*sp**2*(s - sth)**2 - (s - sth)**4 + 140*sp**3*(-s \
+ sth) + 20*sp*(-s + sth)**3)*Log(1 + (s - sth)/sp))/(Pi*(-s + sth)**5) - 
     -  (30*s*(7*s**2 + 7*s*(sp - sth) + 2*(sp - sth)**2)*(s + sp - sth)*
     -     (s**4 + 20*s**3*sp + 90*s**2*sp**2 + 140*s*sp**3 + 70*sp**4 - \
4*(s**3 + 15*s**2*sp + 45*s*sp**2 + 35*sp**3)*sth + 6*(s**2 + 10*s*sp + \
15*sp**2)*sth**2 - 
     -       4*(s + 5*sp)*sth**3 + sth**4)*Log(1 - (s - sth)/(2.*(s + sp - \
sth))))/(Pi*(s - sth)**5*(sp - sth)**4)\
\>", "Output",
