Cell[CellGroupData[{

Cell["S2", "Item",
 CellChangeTimes->{{3.983190704736313*^9, 
  3.98319070491934*^9}},ExpressionUUID->"8e42f0f7-76d6-8c49-826b-\
96ca0434ef72"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"integralSPrime2", "[", 
    RowBox[{
     RowBox[{"s_", "?", "NumericQ"}], ",", 
     RowBox[{"t_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"integrandI2", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"sp", ",", "s2", ",", " ", "Infinity"}], "}"}], ",", 
     RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
     RowBox[{"MaxRecursion", "->", "20"}], ",", 
     RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983190712972006*^9, 3.9831907164523754`*^9}, {
  3.9832822469109764`*^9, 3.9832822478131695`*^9}, {3.9832828418297653`*^9, 
  3.9832828431737633`*^9}},ExpressionUUID->"e1205605-dd6d-d64b-96d4-\
12038db820e6"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"contrib20", "[", 
    RowBox[{"s_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"64", " ", "Pi"}], ")"}]}], ")"}], " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"integralSPrime2", "[", 
       RowBox[{"s", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"s", ",", "x"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "15"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.983190727559435*^9, 3.9831907311998425`*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"a84c68f1-c033-d943-8386-7e96568c4b56"],

