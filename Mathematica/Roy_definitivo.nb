Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Genera", " ", "una", " ", "lista", " ", "de", " ", "puntos", " ", "de", " ",
     "s"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sValues", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"sth", "+", 
        RowBox[{"10", "^", 
         RowBox[{"-", "3"}]}]}], ",", "1.2", ",", "50"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"50", " ", "puntos"}], ",", 
     RowBox[{"ajusta", " ", "si", " ", "quieres", " ", "m\[AAcute]s"}]}], 
    "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Eval\[UAcute]a", " ", 
      RowBox[{"contrib00", "[", "s", "]"}], " ", "en", " ", "cada", " ", 
      "punto"}], ",", 
     RowBox[{"suprimiendo", " ", "warnings"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"contribValues", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"Quiet", "[", 
        RowBox[{
         RowBox[{"contrib00", "[", "#", "]"}], ",", 
         RowBox[{"NIntegrate", "::", "inumr"}]}], "]"}], "&"}], "/@", 
      "sValues"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "Grafica", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"sValues", ",", "contribValues"}], "}"}], "]"}], ",", 
     RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<s\>\"", ",", "\"\<contrib00[s]\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Contribuci\[OAcute]n de la onda S0\>\""}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.983172484201727*^9, 3.9831724950458584`*^9}, {
