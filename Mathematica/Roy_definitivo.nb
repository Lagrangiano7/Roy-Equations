  RowBox[{
   RowBox[{
    RowBox[{"smin", "=", 
     RowBox[{"sth", "+", "0.001"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"tu", " ", "l\[IAcute]mite", " ", "inferior"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"smax", "=", "1.2"}], ";"}], "           ", 
   RowBox[{"(*", 
