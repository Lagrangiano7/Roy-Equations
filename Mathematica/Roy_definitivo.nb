Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"integralSPrime0", "[", 
    RowBox[{
     RowBox[{"s_", "?", "NumericQ"}], ",", 
     RowBox[{"t_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"integrandI0", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"sp", ",", "s2", ",", " ", "Infinity"}], "}"}], ",", 
     RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
     RowBox[{"MaxRecursion", "->", "20"}], ",", 
     RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9832843895167465`*^9, 3.9832843927507877`*^9}},
 CellLabel->
  "In[108]:=",ExpressionUUID->"34a96956-485b-4c41-9278-ee7a6f668d63"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"contrib02", "[", 
    RowBox[{"s_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"64", " ", "Pi"}], ")"}]}], ")"}], " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{"2", ",", " ", "x"}], "]"}], "*", 
       RowBox[{"integralSPrime0", "[", 
        RowBox[{"s", ",", 
         RowBox[{"tt", "[", 
          RowBox[{"s", ",", "x"}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "15"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9832844132970314`*^9, 3.983284427473503*^9}},
 CellLabel->
  "In[109]:=",ExpressionUUID->"934496ed-1fdf-1540-8486-360e59b96e8a"],

