   RowBox[{"(*", 
    RowBox[{"Generamos", " ", "la", " ", "tabla", " ", "de", " ", "valores"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Table", "[", 
