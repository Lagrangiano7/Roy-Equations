    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"LegendreP", "[", 
        RowBox[{"2", ",", " ", "x"}], "]"}], "*", 
       RowBox[{"integralSPrime2", "[", 
