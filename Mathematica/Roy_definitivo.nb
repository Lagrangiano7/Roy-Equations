      RowBox[{"\[Pi]", " ", "sp", 
       RowBox[{"(", 
        RowBox[{"sp", "-", "sth", "+", "t"}], ")"}]}]]}], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["II", 
       RowBox[{"sp", "-", "s"}]], "+", 
      FractionBox["Csu", 
       RowBox[{"sp", "-", "sth", "+", "s", "+", "t"}]]}], ")"}]}]}], 
  ";"}]}], "Input",
