Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"contrib00", "[", 
    RowBox[{"s_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"64", " ", "Pi"}], ")"}]}], ")"}], " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"integralSPrime0", "[", 
       RowBox[{"s", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"s", ",", "x"}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "15"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.98317130716218*^9, 3.983171311759218*^9}, {
   3.983171346499914*^9, 3.9831713713848743`*^9}, {3.983171537178789*^9, 
