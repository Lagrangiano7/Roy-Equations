Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Definimos", " ", "el", " ", "rango", " ", "de", " ", "s", " ", "y", " ", 
    "la", " ", "cantidad", " ", "de", " ", "puntos"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"smin", "=", 
     RowBox[{"sth", "+", "0.001"}]}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{"tu", " ", "l\[IAcute]mite", " ", "inferior"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"smax", "=", "1.2"}], ";"}], "           ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"l\[IAcute]mite", " ", "superior"}], ",", 
     RowBox[{"ajusta", " ", "si", " ", "quieres"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"npoints", "=", "50"}], ";"}], "         ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"n\[UAcute]mero", " ", "de", " ", "puntos"}], ",", 
     RowBox[{
     "puedes", " ", "aumentar", " ", "para", " ", "mayor", " ", 
      "precisi\[OAcute]n"}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generamos", " ", "la", " ", "tabla", " ", "de", " ", "valores"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"s", ",", 
         RowBox[{"contrib11", "[", "s", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"s", ",", "smin", ",", "smax", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"smax", "-", "smin"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"npoints", "-", "1"}], ")"}]}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Exportamos", " ", "a", " ", "un", " ", "archivo", " ", "CSV"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<contrib11_highenergy.csv\>\"", ",", "data"}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9832827890379944`*^9, 3.9832827893418427`*^9}, {
  3.9832828685207005`*^9, 3.983282869061735*^9}},
