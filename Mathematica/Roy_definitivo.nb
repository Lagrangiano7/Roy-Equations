       RowBox[{"s", ",", " ", "t"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"integrand", "[", 
    RowBox[{"s_", ",", " ", "t_", ",", " ", "sp_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"g2", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ".", 
     RowBox[{"ImTI", "[", 
      RowBox[{"sp", ",", " ", "0"}], "]"}]}], " ", "+", " ", 
    RowBox[{
     RowBox[{"g3", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ".", 
     RowBox[{"ImTI", "[", 
      RowBox[{"sp", ",", " ", "t"}], "]"}]}]}]}], ";"}]}], "Input",
