 CellLabel->"In[80]:=",ExpressionUUID->"3b53c53a-1807-204b-85cb-fcccd5a97a48"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"contrib11", "[", 
    RowBox[{"s_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"64", " ", "Pi"}], ")"}]}], ")"}], " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{"x", "*", 
       RowBox[{"integralSPrime1", "[", 
        RowBox[{"s", ",", 
         RowBox[{"tt", "[", 
          RowBox[{"s", ",", "x"}], "]"}]}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
      RowBox[{"MaxRecursion", "->", "15"}], ",", 
      RowBox[{"AccuracyGoal", "->", "5"}]}], "]"}]}]}], ";"}]], "Input",
