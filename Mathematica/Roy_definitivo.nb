Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"integralSPrime1", "[", 
    RowBox[{
     RowBox[{"s_", "?", "NumericQ"}], ",", 
     RowBox[{"t_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{"integrandI1", "[", 
      RowBox[{"s", ",", " ", "t", ",", " ", "sp"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"sp", ",", "s2", ",", " ", "Infinity"}], "}"}], ",", 
     RowBox[{"Method", "->", "\"\<GlobalAdaptive\>\""}], ",", 
     RowBox[{"MaxRecursion", "->", "20"}], ",", 
     RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9831902769405384`*^9, 3.983190304869276*^9}, {
  3.9831927400574627`*^9, 3.983192740944515*^9}, {3.9832827038811817`*^9, 
