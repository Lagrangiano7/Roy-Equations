      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "00"], " ", ",", "0", ",", " ", 
        SubscriptBox["a", "20"]}], ")"}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "th"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g2", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "0"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "th"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g3", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "t"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}]}]}], TraditionalForm]],
