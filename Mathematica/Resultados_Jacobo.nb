Cell[BoxData[
 FractionBox[
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     FractionBox[
      RowBox[{"3", " ", "s"}], 
      RowBox[{
       RowBox[{"-", "s"}], "+", "sp"}]], "+", 
     FractionBox[
      RowBox[{
       RowBox[{"2", " ", "s"}], "+", "sp"}], 
      RowBox[{
       RowBox[{"-", "sp"}], "+", "sth"}]]}], "sp"], "+", 
   FractionBox[
    RowBox[{"2", " ", 
     RowBox[{"Log", "[", 
      FractionBox[
       RowBox[{"s", "+", "sp", "-", "sth"}], "sp"], "]"}]}], 
    RowBox[{"s", "-", "sth"}]]}], 
  RowBox[{"3", " ", "\[Pi]"}]]], "Output",
 CellChangeTimes->{3.9155312583622847`*^9, 3.915532773798019*^9, 
  3.915533080494392*^9, 3.915778072356935*^9, 3.9158470741784697`*^9, 
  3.9158703801135406`*^9, 3.916130765458192*^9},
 CellLabel->"Out[43]=",ExpressionUUID->"332d34ab-336f-44d0-83b7-98324339ee9a"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"K0000S", "[", 
    RowBox[{"s_", ",", "sp_"}], "]"}], "=", 
   RowBox[{
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     FractionBox["1", 
      RowBox[{"sp", "-", "s"}]]}], "-", 
    FractionBox[
     RowBox[{
      RowBox[{"2", "s"}], "+", 
      RowBox[{"5", "sp"}], "-", 
      RowBox[{"4", "sth"}]}], 
     RowBox[{"3", "\[Pi]", " ", "sp", 
      RowBox[{"(", 
       RowBox[{"sp", "-", "sth"}], ")"}]}]], "+", 
    RowBox[{
     FractionBox["2", 
      RowBox[{"3", "\[Pi]", 
       RowBox[{"(", 
        RowBox[{"s", "-", "sth"}], ")"}]}]], 
     RowBox[{"Log", "[", 
      RowBox[{"1", "+", 
       FractionBox[
        RowBox[{"s", "-", "sth"}], "sp"]}], "]"}]}]}]}], ";"}]], "Input",
