Cell[CellGroupData[{

Cell["Computing RY for each parameter variation", "Subsubsection",
 CellChangeTimes->{{3.916628530122593*^9, 3.9166285478346786`*^9}, {
  3.922428634674099*^9, 
  3.9224286360260067`*^9}},ExpressionUUID->"89207a07-3183-4abc-bd6f-\
a47001e80451"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nparRYPWA", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nparRYRegge", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", 
    RowBox[{"k", "<=", 
     RowBox[{"Length", "[", "par", "]"}]}], ",", 
    RowBox[{"k", "++"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalDelta]par", "[", 
        RowBox[{"[", 
         RowBox[{"k", ",", "2"}], "]"}], "]"}], ">", "0"}], ",", 
      RowBox[{"nparRYPWA", "++"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", 
    RowBox[{"k", "<=", 
     RowBox[{"Length", "[", "reggepar", "]"}]}], ",", 
