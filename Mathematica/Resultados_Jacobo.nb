Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"g4", "[", 
    RowBox[{"s_", ",", "t_", ",", "sp_"}], "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"t", "-", "sth"}], "\[Pi]"], " ", 
    RowBox[{"Cst", ".", 
     RowBox[{"(", 
      RowBox[{
       FractionBox["II", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"sp", "-", "t"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"sp", "-", "sth"}], ")"}]}]], "-", 
       FractionBox["Csu", 
