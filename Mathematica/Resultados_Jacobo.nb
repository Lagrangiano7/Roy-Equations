 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"s", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"32", "\[Pi]"}], 
       SubscriptBox["s", "th"]], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"s", 
         FormBox[
          SubscriptBox["I", "2"],
          TraditionalForm]}], "+", 
        RowBox[{"t", 
         FormBox[
          SubscriptBox["C", "st"],
          TraditionalForm]}], "+", 
        RowBox[{"u", 
