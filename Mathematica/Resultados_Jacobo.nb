Cell[CellGroupData[{

Cell["GKPY equations", "Section",
 CellChangeTimes->{{3.824474541718849*^9, 3.824474562840777*^9}, {
  3.824478290443273*^9, 3.824478290518499*^9}, {3.915517105414426*^9, 
  3.91551710728664*^9}, {3.916226956407031*^9, 
  3.9162269604472857`*^9}},ExpressionUUID->"12887062-002f-43fb-92e4-\
6c2a88d2f7e8"],

Cell["\<\
The fixed-t and fixed-s dispersion relation for the three \[Pi]\[Pi] \
amplitudes is\
\>", "Item",
 CellChangeTimes->{{3.915518695504486*^9, 3.915518712705284*^9}, {
  3.9219220036254673`*^9, 
  3.921922014897822*^9}},ExpressionUUID->"9add16ba-40e3-4996-a054-\
c020878815de"],

Cell[CellGroupData[{

Cell[TextData[{
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"s", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{"32", "\[Pi]", 
      FormBox[
       RowBox[{
        SubscriptBox["C", "st"], " "}],
       TraditionalForm], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["a", "00"], " ", ",", "0", ",", " ", 
        SubscriptBox["a", "20"]}], ")"}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "th"], "\[Infinity]"], 
      RowBox[{
       RowBox[{
        SubscriptBox["g", "4"], "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "0"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "th"], "\[Infinity]"], 
      RowBox[{
       RowBox[{
        SubscriptBox["g", "5"], "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "t"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"916d55f2-d3c5-4e8b-872f-2bba1cfed33f"]
}], "Item",
 CellChangeTimes->{
  3.915518716013652*^9, {3.915524683814746*^9, 3.915524944676983*^9}, {
   3.9155313951824703`*^9, 3.915531408822831*^9}, {3.91613091658805*^9, 
   3.916130940548717*^9}, {3.9162270939168987`*^9, 3.916227111361229*^9}, {
   3.916227149916266*^9, 3.9162271548124323`*^9}, {3.921922691486527*^9, 
   3.921922691746458*^9}},ExpressionUUID->"8131c7b1-18f2-447b-b653-\
2d18da3e7726"],

Cell[BoxData[
 RowBox[{"Off", "[", 
  RowBox[{"NIntegrate", "::", "slwcon"}], "]"}]], "Input",
