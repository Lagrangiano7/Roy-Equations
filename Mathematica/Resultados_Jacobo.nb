  3.9163966257303553`*^9}},ExpressionUUID->"c958f17a-7919-465a-97e8-\
258dba00f1ef"],

Cell["The Regge contribution to the amplitude is", "Item",
 CellChangeTimes->{{3.916138425539246*^9, 3.916138447807276*^9}, {
  3.9162220091985683`*^9, 
  3.916222009430356*^9}},ExpressionUUID->"3b89b3e1-9c1a-4a0b-8b7d-\
ece4a668fee9"],

Cell[TextData[{
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "R"], "(", 
     RowBox[{"s", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "A"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g4", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "0"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "A"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g5", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "t"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"2f76c3b5-1504-4674-9ac6-5750271303ca"]
}], "Item",
 CellChangeTimes->{
  3.915518716013652*^9, {3.915524683814746*^9, 3.915524944676983*^9}, {
   3.9155313951824703`*^9, 3.915531408822831*^9}, {3.91613091658805*^9, 
   3.916130940548717*^9}, {3.916138451331661*^9, 3.916138467647678*^9}, {
   3.922359407378467*^9, 
   3.92235941126712*^9}},ExpressionUUID->"925261f2-9a71-44a6-9d60-\
72c651da6b90"],

Cell["but now we have to project in partial wave", "Item",
 CellChangeTimes->{{3.9161384699504757`*^9, 
  3.9161384793276787`*^9}},ExpressionUUID->"dc594823-00fe-4f5e-adc9-\
bb6972747ec3"],

Cell[TextData[{
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      SuperscriptBox["t", "R"], "J"], "(", "s", ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"64", "\[Pi]"}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "1"}], "1"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubsuperscriptBox["\[Integral]", 
           SubscriptBox["s", "A"], "\[Infinity]"], 
          RowBox[{
           RowBox[{"g4", "(", 
            RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
           RowBox[{"ImT", "(", 
            RowBox[{"sp", ",", "0"}], ")"}], 
           RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
         RowBox[{
          SubsuperscriptBox["\[Integral]", 
           SubscriptBox["s", "A"], "\[Infinity]"], 
          RowBox[{
           RowBox[{"g5", "(", 
            RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
           RowBox[{"ImT", "(", 
            RowBox[{"sp", ",", "t"}], ")"}], 
           RowBox[{"\[DifferentialD]", "sp"}]}]}]}], ")"}], 
       RowBox[{
        SubscriptBox["P", "J"], "(", "z", ")"}], "dz"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"fb6957bc-ad3c-4735-82d3-c0461555d251"]
}], "Item",
 CellChangeTimes->{
  3.915518716013652*^9, {3.915524683814746*^9, 3.915524944676983*^9}, {
   3.9155313951824703`*^9, 3.915531408822831*^9}, {3.91613091658805*^9, 
   3.916130940548717*^9}, {3.916138451331661*^9, 3.916138467647678*^9}, {
