Cell["Now we try the analytic integration of the angle dependence", "Item",
 CellChangeTimes->{{3.9161399386384478`*^9, 
  3.916139950576851*^9}},ExpressionUUID->"c0e97623-88a2-4f2a-877a-\
d3a935e71c43"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tRY00RIint", "[", 
    RowBox[{"s_", ",", "sp_"}], "]"}], "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"sp", ">", "sth", ">", "0"}], "&&", 
        RowBox[{"s", "\[Element]", "Complexes"}], "&&", 
        RowBox[{
         FractionBox[
          RowBox[{"s", "-", 
           RowBox[{"2", " ", "sp"}], "+", "sth"}], 
          RowBox[{
           RowBox[{"2", " ", "s"}], "-", 
           RowBox[{"2", " ", "sth"}]}]], "\[NotElement]", 
         TemplateBox[{},
          "Reals"]}], "&&", 
        RowBox[{
         FractionBox[
          RowBox[{"s", "+", 
           RowBox[{"2", " ", "sp"}], "-", "sth"}], 
          RowBox[{
           RowBox[{"2", " ", "s"}], "-", 
           RowBox[{"2", " ", "sth"}]}]], "\[NotElement]", 
         TemplateBox[{},
          "Reals"]}]}], ",", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"32", "\[Pi]"}]], 
        RowBox[{"Integrate", "[", 
         RowBox[{
          RowBox[{"TRY0RI", "[", 
           RowBox[{"s", ",", 
            RowBox[{"tt", "[", 
             RowBox[{"s", ",", "z"}], "]"}], ",", "sp"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"z", ",", "0", ",", "1"}], "}"}]}], "]"}]}]}], "]"}], ",", 
     
     RowBox[{"sp", ">", "s", ">", "sth", ">", "0"}]}], "]"}]}], 
  "\[IndentingNewLine]"}]], "Text",
 CellChangeTimes->{{3.916139952154146*^9, 3.916140013117236*^9}, {
   3.916228498862809*^9, 3.916228526334454*^9}, {3.916234086139327*^9, 
   3.916234111891575*^9}, {3.916237633634624*^9, 3.9162376497731123`*^9}, {
   3.916237751532296*^9, 3.9162377714051237`*^9}, 3.916461288704878*^9, {
   3.916466837081292*^9, 3.916466837320469*^9}, {3.922359622915141*^9, 
   3.92235962742931*^9}, 3.9223597022985363`*^9, {3.922423013921254*^9, 
   3.9224230169292183`*^9}, 3.922423144119822*^9},
 CellLabel->
  "In[1768]:=",ExpressionUUID->"9530c11b-4d7f-402d-9968-f4b3af131900"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"s", "-", "sth"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], " ", "sp"}], "+", "sth"}], ")"}]}], ")"}]}], "+", 
     RowBox[{"2", " ", "sp", " ", 
      RowBox[{"(", 
       RowBox[{"sp", "-", "sth"}], ")"}], " ", 
      RowBox[{"Log", "[", 
       FractionBox[
        RowBox[{"sp", " ", 
         RowBox[{"(", 
          RowBox[{"s", "-", 
           RowBox[{"2", " ", "sp"}], "+", "sth"}], ")"}]}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"s", "+", 
           RowBox[{"2", " ", "sp"}], "-", "sth"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "sp"}], "+", "sth"}], ")"}]}]], "]"}]}]}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"sp", " ", 
      SubscriptBox["\[Beta]", "P"]}], "+", 
     RowBox[{
      SuperscriptBox["sp", 
       SubscriptBox["\[Alpha]", 
        SuperscriptBox["P", "p0"]]], " ", 
      SubscriptBox["\[Beta]", 
       SuperscriptBox["P", "p"]]}]}], ")"}]}], 
  RowBox[{"8", " ", "sp", " ", 
   RowBox[{"(", 
    RowBox[{"sp", "-", "sth"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "s"}], "+", "sth"}], ")"}]}]]], "Text",
 CellChangeTimes->{3.922423034998251*^9, 3.922423144189402*^9},
 CellLabel->
  "Out[1768]=",ExpressionUUID->"dfb19f0b-6333-4e3d-b6a1-bbf119602e43"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tRY00RIint", "[", 
    RowBox[{"s_", ",", "sp_"}], "]"}], "=", 
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"s", "-", "sth"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", "sp"}], "+", "sth"}], ")"}]}], ")"}]}], 
       "+", 
       RowBox[{"2", " ", "sp", " ", 
        RowBox[{"(", 
         RowBox[{"sp", "-", "sth"}], ")"}], " ", 
        RowBox[{"Log", "[", 
         FractionBox[
          RowBox[{"sp", " ", 
           RowBox[{"(", 
            RowBox[{"s", "-", 
             RowBox[{"2", " ", "sp"}], "+", "sth"}], ")"}]}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"s", "+", 
             RowBox[{"2", " ", "sp"}], "-", "sth"}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "sp"}], "+", "sth"}], ")"}]}]], "]"}]}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"sp", " ", 
        SubscriptBox["\[Beta]", "P"]}], "+", 
       RowBox[{
        SuperscriptBox["sp", 
         SubscriptBox["\[Alpha]", 
          SuperscriptBox["P", "p0"]]], " ", 
        SubscriptBox["\[Beta]", 
         SuperscriptBox["P", "p"]]}]}], ")"}]}], 
    RowBox[{"8", " ", "sp", " ", 
     RowBox[{"(", 
      RowBox[{"sp", "-", "sth"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "s"}], "+", "sth"}], ")"}]}]]}], ";"}]], "Input",
 CellChangeTimes->{{3.922359693418495*^9, 3.922359699057665*^9}, 
   3.922423141476821*^9},
 CellLabel->
