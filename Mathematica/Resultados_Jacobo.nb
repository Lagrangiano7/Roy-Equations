Cell[BoxData[{
 RowBox[{
  RowBox[{"par", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
    "S0par", ",", "Ppar", ",", "S2par", ",", "D0par", ",", "D2par", ",", 
     "Fpar"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]par", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
    "\[CapitalDelta]S0par", ",", "\[CapitalDelta]Ppar", ",", 
     "\[CapitalDelta]S2par", ",", "\[CapitalDelta]D0par", ",", 
     "\[CapitalDelta]D2par", ",", "\[CapitalDelta]Fpar"}], "]"}]}], 
  ";"}]}], "Input",
