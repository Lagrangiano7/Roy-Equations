Cell[CellGroupData[{

Cell["Kinematics", "Subsection",
 CellChangeTimes->{{3.915526374810351*^9, 
  3.915526379229014*^9}},ExpressionUUID->"e857a165-4b31-4e35-9608-\
06e75b95698a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"tt", "[", 
    RowBox[{"s_", ",", "z_"}], "]"}], "=", 
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"(", 
     RowBox[{"sth", "-", "s"}], ")"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", "z"}], ")"}]}]}], ";"}]], "Input",
