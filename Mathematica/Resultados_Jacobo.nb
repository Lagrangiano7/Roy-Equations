b03bc5f75d12"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"KT", "[", 
    RowBox[{"s_", ",", "sp_", ",", "z_", ",", "Jp_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", "Jp"}], "+", "1"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"g2", "[", 
       RowBox[{"s", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"s", ",", "z"}], "]"}], ",", "sp"}], "]"}], "+", 
      RowBox[{
       RowBox[{"g3", "[", 
        RowBox[{"s", ",", 
         RowBox[{"tt", "[", 
          RowBox[{"s", ",", "z"}], "]"}], ",", "sp"}], "]"}], 
       RowBox[{"LegendreP", "[", 
        RowBox[{"Jp", ",", 
         RowBox[{"zp", "[", 
          RowBox[{"s", ",", "sp", ",", "z"}], "]"}]}], "]"}]}]}], ")"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.915525774426092*^9, 3.915525845877122*^9}, 
   3.915525890726074*^9, {3.915525963767087*^9, 3.9155259802956448`*^9}, {
