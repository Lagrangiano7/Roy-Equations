  3.915531791270219*^9}},ExpressionUUID->"913252bb-d735-42be-bcbe-\
16edd1f9ab0f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"KK00", "[", 
   RowBox[{"s_", ",", "sp_", ",", "J_", ",", "Jp_"}], "]"}], ":=", 
  RowBox[{"Assuming", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"sp", ">", "sth", ">", "0"}], "&&", 
     RowBox[{"s", "\[Element]", "Complexes"}], "&&", 
     RowBox[{
      FractionBox["1", 
       RowBox[{"s", "-", "sth"}]], "\[NotElement]", 
      TemplateBox[{},
       "Reals"]}]}], ",", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"LegendreP", "[", 
         RowBox[{"J", ",", "z"}], "]"}], 
        RowBox[{"KT00", "[", 
         RowBox[{"s", ",", "sp", ",", "z", ",", "Jp"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.915526061915244*^9, 3.915526169635582*^9}, {
   3.915526413064945*^9, 3.915526419785211*^9}, {3.9155284311234207`*^9, 
   3.915528433920094*^9}, {3.915528600285939*^9, 3.9155286039961863`*^9}, {
   3.915528676940556*^9, 3.915528690461019*^9}, 3.915530163290794*^9, {
