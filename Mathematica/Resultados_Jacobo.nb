Cell[BoxData[
 RowBox[{
  RowBox[{"t00DT", "[", 
   RowBox[{"s_", ",", "par_"}], "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"K0002S", "[", 
          RowBox[{"s", ",", "sp"}], "]"}], 
         RowBox[{"imt02", "[", "sp", "]"}]}], "+", 
        RowBox[{
         RowBox[{"K0013S", "[", 
          RowBox[{"s", ",", "sp"}], "]"}], 
         RowBox[{"imt13", "[", "sp", "]"}]}], "+", 
        RowBox[{
         RowBox[{"K0022S", "[", 
          RowBox[{"s", ",", "sp"}], "]"}], 
         RowBox[{"imt22", "[", "sp", "]"}]}]}], ")"}], "/.", "par"}], "/.", 
     "physval"}], ",", 
    RowBox[{"{", 
     RowBox[{"sp", ",", 
      RowBox[{"4", 
       SuperscriptBox["M", "2"]}], ",", "s", ",", 
      SuperscriptBox["1.42", "2"]}], "}"}], ",", 
