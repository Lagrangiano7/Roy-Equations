Cell[BoxData[{
 RowBox[{
  RowBox[{"nparRoyPWA", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nparRoyRegge", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", 
    RowBox[{"k", "<=", 
     RowBox[{"Length", "[", "par", "]"}]}], ",", 
    RowBox[{"k", "++"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalDelta]par", "[", 
        RowBox[{"[", 
         RowBox[{"k", ",", "2"}], "]"}], "]"}], ">", "0"}], ",", 
      RowBox[{"nparRoyPWA", "++"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", 
    RowBox[{"k", "<=", 
     RowBox[{"Length", "[", "reggepar", "]"}]}], ",", 
    RowBox[{"k", "++"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalDelta]reggepar", "[", 
        RowBox[{"[", 
         RowBox[{"k", ",", "2"}], "]"}], "]"}], ">", "0"}], ",", 
      RowBox[{"nparRoyRegge", "++"}]}], "]"}]}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.916475860391309*^9, 3.916475869308468*^9}, {
  3.9164759490813017`*^9, 3.916475949276803*^9}, {3.916475984041704*^9, 
