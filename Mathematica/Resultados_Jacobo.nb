Cell[CellGroupData[{

Cell["g2 and g3 functions", "Subsection",
 CellChangeTimes->{{3.915524968352322*^9, 3.915524972517228*^9}, {
  3.915525070325453*^9, 3.915525070890211*^9}, {3.9157784515550756`*^9, 
  3.915778456367956*^9}, {3.9157784888883142`*^9, 3.915778491264377*^9}, {
  3.9158470416245327`*^9, 
  3.915847045848127*^9}},ExpressionUUID->"19b2a40c-f872-4297-88cd-\
7c4b535be911"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", 
    RowBox[{"s_", ",", "t_", ",", "sp_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["t", 
      RowBox[{"\[Pi]", " ", "sp", 
       RowBox[{"(", 
        RowBox[{"sp", "-", "sth"}], ")"}]}]]}], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"sth", "-", "s", "-", "t"}], ")"}], " ", "Cst"}], "+", 
       RowBox[{"s", " ", 
        RowBox[{"Cst", ".", "Ctu"}]}]}], ")"}], ".", 
     RowBox[{"(", 
      RowBox[{
       FractionBox["II", 
        RowBox[{"sp", "-", "t"}]], "+", 
       FractionBox["Csu", 
        RowBox[{"sp", "-", "sth", "+", "t"}]]}], ")"}]}]}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.915524994538455*^9, 3.9155250648583193`*^9}, {
   3.915525134355983*^9, 3.9155251349400177`*^9}, 3.915525853917758*^9, {
   3.915527592960287*^9, 3.915527609074345*^9}, 3.91552874757546*^9, {
   3.9155299343479443`*^9, 3.915529935160975*^9}, 3.915530802754518*^9, 
   3.91553120887683*^9},
 CellLabel->
  "In[1834]:=",ExpressionUUID->"02add326-7c02-4829-b905-1f1f52e4a742"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"g3", "[", 
    RowBox[{"s_", ",", "t_", ",", "sp_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"s", " ", 
       RowBox[{"(", 
        RowBox[{"sth", "-", "s", "-", "t"}], ")"}]}], 
      RowBox[{"\[Pi]", " ", "sp", 
       RowBox[{"(", 
        RowBox[{"sp", "-", "sth", "+", "t"}], ")"}]}]]}], 
    RowBox[{"(", 
     RowBox[{
      FractionBox["II", 
       RowBox[{"sp", "-", "s"}]], "+", 
      FractionBox["Csu", 
       RowBox[{"sp", "-", "sth", "+", "s", "+", "t"}]]}], ")"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.91552507291588*^9, 3.915525158580286*^9}, {
  3.915525856157776*^9, 3.9155258709660873`*^9}},
 CellLabel->
  "In[1835]:=",ExpressionUUID->"0129f5c8-b843-45b0-b0f0-72e49f90e343"]
}, Open  ]],

