Cell[BoxData[
 RowBox[{
  RowBox[{"toRK1", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"pi", "->", " ", "\[Pi]"}], ",", 
     RowBox[{"y1", "->", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "/", "2"}], ")"}], "*", 
       RowBox[{"Log", "[", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "4"}], "+", "s", "+", 
            RowBox[{"2", "*", "sp"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"4", "+", "s", "-", 
            RowBox[{"2", "*", "sp"}]}], ")"}]}], ")"}], "]"}]}]}], ",", 
     RowBox[{"y2", "->", 
      RowBox[{
       RowBox[{"1", "/", "2"}], "*", 
       RowBox[{"Log", "[", 
        RowBox[{"(", 
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "4"}], "+", "s", "+", "sp"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "4"}], "+", "sp"}], ")"}]}], ")"}]}], ")"}], 
        "]"}]}]}], ",", 
     RowBox[{"var", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "+", "s", "-", 
          RowBox[{"2", "*", "sp"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"8", "-", 
          RowBox[{"2", "*", "sp"}]}], ")"}]}], ")"}]}], ",", 
     RowBox[{"var0", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "4"}], "-", "s", "+", 
        RowBox[{"2", "*", "sp"}]}], ")"}]}], ",", 
     RowBox[{"var1", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "4"}], "+", "s", "+", 
          RowBox[{"2", "*", "sp"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"4", "+", "s", "-", 
          RowBox[{"2", "*", "sp"}]}], ")"}]}], ")"}]}], ",", 
     RowBox[{"var2", "->", 
      RowBox[{"(", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "4"}], "+", "s", "+", "sp"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "4"}], "+", "sp"}], ")"}]}], ")"}]}], ")"}]}], ",", 
     RowBox[{"var3", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["s", "2"]}], "+", 
        RowBox[{"4", "*", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "2"}], "+", "sp"}], ")"}], "2"]}]}], ")"}]}], ",", 
     RowBox[{"CDLOG", "->", "Log"}], ",", 
     RowBox[{"Log2", "->", 
      RowBox[{"Log", "[", "2", "]"}]}], ",", 
     RowBox[{"Log4", "->", 
      RowBox[{"Log", "[", "4", "]"}]}], ",", 
     RowBox[{"Log16", "->", 
      RowBox[{"Log", "[", "16", "]"}]}], ",", 
     RowBox[{"Log256", "->", 
      RowBox[{"Log", "[", "256", "]"}]}]}], "}"}]}], ";"}]], "Input",
