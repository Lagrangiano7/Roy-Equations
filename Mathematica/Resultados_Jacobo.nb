Cell[CellGroupData[{

Cell["Regge contribution", "Subsection",
 CellChangeTimes->{{3.915524968352322*^9, 3.915524972517228*^9}, {
  3.915525070325453*^9, 3.915525070890211*^9}, {3.9157784515550756`*^9, 
  3.915778456367956*^9}, {3.9157784888883142`*^9, 3.915778491264377*^9}, {
  3.9157785279131517`*^9, 3.915778535984858*^9}, {3.9161377912651978`*^9, 
  3.9161377950365334`*^9}, {3.921820562348463*^9, 
  3.921820563276505*^9}},ExpressionUUID->"f2fa9bef-5fff-4c43-a354-\
8fd10608a2a8"],

Cell[CellGroupData[{

Cell["Formulas", "Subsubsection",
 CellChangeTimes->{{3.916396622128442*^9, 
  3.9163966257303553`*^9}},ExpressionUUID->"cf187298-c43f-42b2-9329-\
211e4f8e117d"],

Cell["The Regge contribution to the amplitude is", "Item",
 CellChangeTimes->{{3.916138425539246*^9, 3.916138447807276*^9}, {
  3.9162220091985683`*^9, 
  3.916222009430356*^9}},ExpressionUUID->"323fcf94-6b71-44f5-8f70-\
92df9a1b2776"],

Cell[TextData[{
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "R"], "(", 
     RowBox[{"s", ",", "t"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "A"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g2", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "0"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       SubscriptBox["s", "A"], "\[Infinity]"], 
      RowBox[{
       RowBox[{"g3", "(", 
        RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
       RowBox[{"ImT", "(", 
        RowBox[{"sp", ",", "t"}], ")"}], 
       RowBox[{"\[DifferentialD]", "sp"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"0ff34dbf-7d9f-4ffa-9fcd-5690c248f7d6"]
}], "Item",
 CellChangeTimes->{
  3.915518716013652*^9, {3.915524683814746*^9, 3.915524944676983*^9}, {
   3.9155313951824703`*^9, 3.915531408822831*^9}, {3.91613091658805*^9, 
   3.916130940548717*^9}, {3.916138451331661*^9, 
   3.916138467647678*^9}},ExpressionUUID->"273cb510-8251-42e3-93ac-\
f835ff7c13a0"],

Cell["but now we have to project in partial wave", "Item",
 CellChangeTimes->{{3.9161384699504757`*^9, 
  3.9161384793276787`*^9}},ExpressionUUID->"ab062e9c-9ab0-4fee-976f-\
d9b1ef537309"],

Cell[TextData[{
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      SuperscriptBox["t", "R"], "J"], "(", "s", ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"64", "\[Pi]"}]], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "1"}], "1"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubsuperscriptBox["\[Integral]", 
           SubscriptBox["s", "A"], "\[Infinity]"], 
          RowBox[{
           RowBox[{"g2", "(", 
            RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
           RowBox[{"ImT", "(", 
            RowBox[{"sp", ",", "0"}], ")"}], 
           RowBox[{"\[DifferentialD]", "sp"}]}]}], "+", 
         RowBox[{
          SubsuperscriptBox["\[Integral]", 
           SubscriptBox["s", "A"], "\[Infinity]"], 
          RowBox[{
           RowBox[{"g3", "(", 
            RowBox[{"s", ",", "t", ",", "sp"}], ")"}], 
           RowBox[{"ImT", "(", 
            RowBox[{"sp", ",", "t"}], ")"}], 
           RowBox[{"\[DifferentialD]", "sp"}]}]}]}], ")"}], 
       RowBox[{
        SubscriptBox["P", "J"], "(", "z", ")"}], "dz"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"3d722ba0-eed1-4d19-b2aa-45b58eb375b2"]
}], "Item",
 CellChangeTimes->{
  3.915518716013652*^9, {3.915524683814746*^9, 3.915524944676983*^9}, {
   3.9155313951824703`*^9, 3.915531408822831*^9}, {3.91613091658805*^9, 
   3.916130940548717*^9}, {3.916138451331661*^9, 3.916138467647678*^9}, {
   3.916138540969586*^9, 
   3.916138634307139*^9}},ExpressionUUID->"1a618228-d54b-464b-a941-\
0151a00ad396"],

Cell["Is there an analytic calculation?", "Item",
 CellChangeTimes->{{3.916138644187921*^9, 
  3.91613865685082*^9}},ExpressionUUID->"f13e49fc-6cdc-4909-bdfd-\
ff8d4244712b"],

Cell[CellGroupData[{

Cell["First we compute the different imaginary part contributions", "Item",
 CellChangeTimes->{{3.916139094673725*^9, 
  3.916139105107793*^9}},ExpressionUUID->"21ecccee-92e4-4643-a67d-\
fc15e3cff40f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ImF0R", "[", 
    RowBox[{"s_", ",", "t_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"4", 
     SuperscriptBox["\[Pi]", "2"], " ", 
     RowBox[{
      RowBox[{"Cst", "[", 
       RowBox[{"[", "1", "]"}], "]"}], ".", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ImF0t", "[", 
         RowBox[{"s", ",", "t"}], "]"}], ",", 
        RowBox[{"ImF1t", "[", 
         RowBox[{"s", ",", "t"}], "]"}], ",", 
        RowBox[{"ImF2t", "[", 
         RowBox[{"s", ",", "t"}], "]"}]}], "}"}]}]}], "//", 
    "FullSimplify"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.916138814566221*^9, 3.91613883086195*^9}, {
   3.916139108476222*^9, 3.9161391127720757`*^9}, {3.9161391542695913`*^9, 
   3.916139192648081*^9}, {3.916139275329948*^9, 3.916139277265362*^9}, {
   3.916228417055571*^9, 3.916228422398301*^9}, 3.916397330907785*^9, {
   3.91639822554632*^9, 3.9163982308496943`*^9}, 3.916407251871673*^9, {
   3.9223646388503428`*^9, 
   3.922364644717779*^9}},ExpressionUUID->"43b251f5-df2e-4544-a081-\
0fc83c1b0dfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ImF1R", "[", 
    RowBox[{"s_", ",", "t_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"4", 
     SuperscriptBox["\[Pi]", "2"], 
     RowBox[{
      RowBox[{"Cst", "[", 
       RowBox[{"[", "2", "]"}], "]"}], ".", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ImF0t", "[", 
         RowBox[{"s", ",", "t"}], "]"}], ",", 
        RowBox[{"ImF1t", "[", 
         RowBox[{"s", ",", "t"}], "]"}], ",", 
        RowBox[{"ImF2t", "[", 
         RowBox[{"s", ",", "t"}], "]"}]}], "}"}]}]}], "//", 
    "FullSimplify"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9161392013111467`*^9, 3.916139203974869*^9}, 
   3.916139279145586*^9, 3.916397332043497*^9, 3.9163982349629307`*^9, 
   3.9164072536278753`*^9, 
   3.922364647377866*^9},ExpressionUUID->"2c2d1d3d-3bc6-4904-bdc3-\
b62c45c272c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ImF2R", "[", 
