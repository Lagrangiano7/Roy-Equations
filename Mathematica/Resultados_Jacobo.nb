Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalDelta]err", "[", 
    RowBox[{"f_", ",", "r_", ",", "\[CapitalDelta]r_", ",", "n_"}], "]"}], ":=", 
   SqrtBox[
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], "n"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[PartialD]", 
          RowBox[{"r", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "1"}], "]"}], "]"}]], "f"}], ")"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"\[CapitalDelta]r", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "2"}], "]"}], "]"}], "2"]}]}]]}], ";"}]], "Input",
