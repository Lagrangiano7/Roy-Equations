
@misc{yndurain_low_2003,
	title = {Low {Energy} {Pion} {Physics}},
	url = {http://arxiv.org/abs/hep-ph/0212282},
	doi = {10.48550/arXiv.hep-ph/0212282},
	abstract = {In these notes we present an introductory review on various topics about low energy pion physics (some kaon physics is discussed as well). Among these, we include the uses of analyticity and unitarity to describe partial wave amplitudes (for which we give accurate and economical parametrizations) and form factors; (forward) dispersion relations; and the use of the Froissart–Gribov representation to evaluate accurately the low energy parameters (scattering lengths and eﬀective ranges) for higher (l ≥ 1) waves. Finally, we describe some pion physics in QCD and then pass on to study the nonlinear sigma model, and the chiral perturbation theory approach to low energy pion interactions.},
	language = {en},
	urldate = {2026-01-22},
	publisher = {arXiv},
	author = {Yndurain, F. J.},
	month = oct,
	year = {2003},
	note = {arXiv:hep-ph/0212282},
	keywords = {High Energy Physics - Phenomenology},
	annote = {Comment: Plain TeX file. Completely revised, updated and improved version},
	file = {PDF:C\:\\Users\\germa\\Zotero\\storage\\V2PA6D3T\\Yndurain - 2003 - Low Energy Pion Physics.pdf:application/pdf},
}

@misc{scherer_introduction_2002,
	title = {Introduction to {Chiral} {Perturbation} {Theory}},
	url = {http://arxiv.org/abs/hep-ph/0210398},
	doi = {10.48550/arXiv.hep-ph/0210398},
	abstract = {This article provides a pedagogical introduction to the basic concepts of chiral perturbation theory and is designed as a text for a two-semester course on that topic. Chapter 1 serves as a general introduction to the empirical and theoretical foundations which led to the development of chiral perturbation theory. Chapter 2 deals with QCD and its global symmetries in the chiral limit; the concept of Green functions and Ward identities reflecting the underlying chiral symmetry is elaborated. In Chap. 3 the idea of a spontaneous breakdown of a global symmetry is discussed and its consequences in terms of the Goldstone theorem are demonstrated. Chapter 4 deals with mesonic chiral perturbation theory and the principles entering the construction of the chiral Lagrangian are outlined. Various examples with increasing chiral orders and complexity are given. Finally, in Chap. 5 the methods are extended to include the interaction between Goldstone bosons and baryons in the single-baryon sector, with the main emphasis put on the heavy-baryon formulation. At the end, the method of infrared regularization in the relativistic framework is discussed.},
	language = {en},
	urldate = {2026-01-22},
	publisher = {arXiv},
	author = {Scherer, S.},
	month = oct,
	year = {2002},
	note = {arXiv:hep-ph/0210398},
	keywords = {High Energy Physics - Phenomenology, High Energy Physics - Experiment, High Energy Physics - Theory, Nuclear Experiment, Nuclear Theory},
	annote = {Comment: 299 pages, LaTex2e, 27 figures, to appear in "Advances in Nuclear Physics", Vol. 27, edited by J. W. Negele and E. Vogt},
	file = {PDF:C\:\\Users\\germa\\Zotero\\storage\\TM639Z8N\\Scherer - 2002 - Introduction to Chiral Perturbation Theory.pdf:application/pdf},
}

